!function(){const e=document.querySelector(".timeline ol"),t=document.querySelectorAll(".timeline li > div.content-wrap"),n=document.querySelectorAll(".timeline li > div.content-wrap .content");if(e>0){function i(e,t,n){let i=0;for(let n=0;n<e.length;n++){const e=t[n].offsetHeight;i<e&&(i=e)}for(let t=0;t<e.length;t++)e[t].style.height=`${i+10}px`;n.style.padding=`${i+50}px 0`}window.addEventListener("load",function(){i(t,n,e)}),window.addEventListener("resize",function(){setTimeout(function(){i(t,n,e)},1500)})}}();