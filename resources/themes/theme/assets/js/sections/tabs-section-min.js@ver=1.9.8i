jQuery(document).ready(function(t){if(t(".tab-title").length){let e=t(".tab-title"),a=t(".tab-list"),c=t(".navigation--prev"),l=t(".navigation--next");function i(i){let e=t(".tab-title.active");if(!0===i){let i=t(e).next();-1===i.index()?t(".tab-title").eq(0).trigger("click"):i.trigger("click")}else{let i=t(e).prev();-1===i.index()?t(".tab-title").eq(a.length-1).trigger("click"):i.trigger("click")}}e.on("click",function(){if(!t(this).hasClass("active")){e.removeClass("active"),t(this).addClass("active"),a.removeClass("active");let i=t(this).data("tab");t("#"+i).addClass("active")}}),c.on("click",function(){i(!1)}),l.on("click",function(){i(!0)})}});